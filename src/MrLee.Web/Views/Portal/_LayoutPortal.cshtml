@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    var nombre = User.Identity?.Name ?? "";
    var esCliente = User.FindFirst("ClienteId") != null;
}
<!doctype html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] ?? "Mr Lee") – Portal Clientes</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Playfair+Display:wght@600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/theme/css/site.css" rel="stylesheet" />
    <link href="/theme/css/portal.css" rel="stylesheet" />
</head>
<body class="portal-body">

    <nav class="portal-nav navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/Portal">
                <div class="portal-logo-circle">
                    <img src="/theme/img/logo.jpeg" alt="Mr Lee"
                         onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                    <span style="display:none">ML</span>
                </div>
                <div>
                    <div class="fw-bold lh-1" style="color:#fff;font-size:1rem;">Mr Lee</div>
                    <small style="color:rgba(255,255,255,.65);font-size:.72rem;">Panadería artesanal</small>
                </div>
            </a>

            <button class="navbar-toggler border-0" type="button"
                    data-bs-toggle="collapse" data-bs-target="#portalNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="portalNav">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Portal" asp-action="Index">🏠 Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Portal" asp-action="Nosotros">ℹ️ Nosotros</a>
                    </li>
                    @if (esCliente)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Portal" asp-action="HacerPedido">🛒 Hacer pedido</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Portal" asp-action="MisPedidos">📦 Mis pedidos</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Portal" asp-action="Perfil">👤 Mi perfil</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Portal" asp-action="Preferencias">🔔 Notificaciones</a>
                        </li>
                    }
                </ul>

                <div class="d-flex align-items-center gap-2">
                    @if (esCliente)
                    {
                        <span class="navbar-text small" style="color:rgba(255,255,255,.8);">
                            Hola, <strong>@nombre</strong>
                        </span>
                        <a href="/Portal/Logout"
                           class="btn btn-sm"
                           style="background:var(--primary);color:#fff;border:none;border-radius:999px;padding:.4rem .85rem;">
                            Salir
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Portal" asp-action="Login"
                           class="btn btn-sm btn-outline-light">Iniciar sesión</a>
                        <a asp-controller="Portal" asp-action="Registro"
                           class="btn btn-sm" style="background:var(--primary);color:#fff;">Registrarse</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="portal-main">
        @if (TempData["Msg"] != null)
        {
            <div class="container pt-3">
                <div class="alert alert-success border-0 shadow-sm">@TempData["Msg"]</div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container pt-3">
                <div class="alert alert-danger border-0 shadow-sm">@TempData["Error"]</div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="portal-footer py-4">
        <div class="container">
            <div class="row g-3 align-items-center">
                <div class="col-md-4 text-center text-md-start">
                    <strong style="color:#fff;">Mr Lee Panadería</strong>
                    <div class="small mt-1">Horneado con amor desde 2018</div>
                </div>
                <div class="col-md-4 text-center small">
                    📍 Av. Principal 100, San José · 📞 2222-3333
                </div>
                <div class="col-md-4 text-center text-md-end small">
                    © @DateTime.Now.Year Mr Lee — Todos los derechos reservados
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>